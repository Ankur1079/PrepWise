{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile containing name and optionally custom Gemini API credentials",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "geminiEmail": {
          "type": "string"
        },
        "geminiApiKey": {
          "type": "string"
        },
        "createdAt": {
          "type": "string"
        }
      },
      "required": [
        "uid",
        "name",
        "email",
        "createdAt"
      ]
    },
    "InterviewSession": {
      "title": "InterviewSession",
      "description": "Completed interview session with full performance metrics feedback details",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string"
        },
        "role": {
          "type": "string"
        },
        "difficulty": {
          "type": "string"
        },
        "topic": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "score": {
          "type": "number"
        },
        "feedback": {
          "type": "object"
        },
        "createdAt": {
          "type": "string"
        },
        "duration": {
          "type": "number"
        }
      },
      "required": [
        "userId",
        "role",
        "difficulty",
        "topic",
        "status",
        "createdAt"
      ]
    },
    "CustomTemplate": {
      "title": "CustomTemplate",
      "description": "Custom practice template added by the user",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string"
        },
        "role": {
          "type": "string"
        },
        "topic": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "icon": {
          "type": "string"
        },
        "createdAt": {
          "type": "string"
        }
      },
      "required": [
        "userId",
        "role",
        "topic",
        "description",
        "createdAt"
      ]
    },
    "UserFeedback": {
      "title": "UserFeedback",
      "description": "User experience feedback containing rating, improvements, and error notes",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string"
        },
        "userEmail": {
          "type": "string"
        },
        "rating": {
          "type": "string"
        },
        "improvements": {
          "type": "string"
        },
        "difficultSteps": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "createdAt": {
          "type": "string"
        }
      },
      "required": [
        "rating",
        "improvements",
        "difficultSteps",
        "createdAt"
      ]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles containing general parameters and settings info"
    },
    "/interviews/{interviewId}": {
      "schema": "InterviewSession",
      "description": "All completed candidate interviews containing final feedback metrics"
    },
    "/custom_templates/{templateId}": {
      "schema": "CustomTemplate",
      "description": "Custom practice templates created by the user"
    },
    "/feedbacks/{feedbackId}": {
      "schema": "UserFeedback",
      "description": "User experience feedback submissions"
    }
  }
}
