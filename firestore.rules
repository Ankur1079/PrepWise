rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Users Collection rules
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Interviews Collection rules
    match /interviews/{interviewId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Custom Templates Collection rules
    match /custom_templates/{templateId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Feedbacks Collection rules
    match /feedbacks/{feedbackId} {
      allow create: if true;
      allow read, delete: if isSignedIn() && request.auth.token.email == "ankuryadav1079@gmail.com";
    }
  }
}
